# --- Server ---
PORT=8000
SIMULATOR_INTERVAL_MS=8000

# --- LLM fallback chain (all optional — bot works without any of these,
#     falling back to templates if none are configured or all fail) ---
# Free tier: https://console.groq.com
GROQ_API_KEY=
# Free tier: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Free tier: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Discord bot ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_ADMIN_ROLE_ID=

# --- Backend URL the bot process talks to ---
BACKEND_URL=http://localhost:8000
